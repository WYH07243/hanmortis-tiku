// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ==================== Auth.js 认证模型 ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?   // 邮箱密码登录用

  accounts          Account[]
  sessions          Session[]
  questionBanks     QuestionBank[]
  practiceRecords   PracticeRecord[]
  wrongQuestions    WrongQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

// ==================== 业务模型 ====================

// 题库
model QuestionBank {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions  Question[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 题目
model Question {
  id             String   @id @default(cuid())
  questionBankId String
  type           QuestionType
  content        Json     // 题目内容（JSON格式，包含题干、选项等信息）
  answer         Json     // 答案（JSON格式，结构化答案）
  explanation    String?  // 解析
  difficulty     Int      @default(1) // 难度 1-5
  tags           String   @default("[]") // 标签 (JSON数组)
  sourceFile     String?  // 来源文件名

  questionBank QuestionBank     @relation(fields: [questionBankId], references: [id], onDelete: Cascade)
  records      PracticeRecord[]
  wrongBy      WrongQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum QuestionType {
  CHOICE        // 选择题
  TRUE_FALSE    // 判断题
  SHORT_ANSWER  // 简答题/问答题
  CALCULATION   // 计算题
}

// 练习记录
model PracticeRecord {
  id          String   @id @default(cuid())
  userId      String
  questionId  String
  isCorrect   Boolean
  userAnswer  Json     // 用户提交的答案
  timeSpent   Int?     // 用时（秒）
  mode        PracticeMode @default(PRACTICE)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum PracticeMode {
  PRACTICE  // 练习模式
  EXAM      // 考试模式
  REVIEW    // 复习模式
}

// 错题本
model WrongQuestion {
  id          String   @id @default(cuid())
  userId      String
  questionId  String
  wrongCount  Int      @default(1)
  lastWrongAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}
